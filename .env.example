# 网站URL（用于sitemap和robots.txt生成）
SITE_URL=https://your-domain.com

# Cloudflare API Token（用于自动部署）
# 获取方式：Cloudflare Dashboard > My Profile > API Tokens > Create Token
# 需要的权限：Account > Cloudflare Pages > Edit
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token

# Cloudflare Account ID
# 获取方式：Cloudflare Dashboard > Workers & Pages > 右侧复制 Account ID
CLOUDFLARE_ACCOUNT_ID=your_account_id

# 项目名称（Cloudflare Pages项目名）
PROJECT_NAME=webstacknav
