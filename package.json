{
  "name": "wow-navigation",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "npm run sync-settings && vite build && npm run copy-functions && npm run generate-static && npm run generate-detail-template && npm run generate-favorites-sitemap",
    "build:static": "vite build && npm run copy-functions && npm run generate-static && npm run generate-seo && npm run generate-favorites-sitemap",
    "sync-settings": "node scripts/sync-settings.js",
    "generate-static": "node scripts/generate-static.js",
    "generate-detail-template": "node scripts/generate-detail-template.js",
    "generate-favorites-sitemap": "node scripts/generate-favorites-sitemap.js",
    "generate-seo": "node scripts/generate-seo.js",
    "copy-functions": "node -e \"const fs=require('fs');const path=require('path');function copyDir(s,d){fs.mkdirSync(d,{recursive:true});fs.readdirSync(s).forEach(f=>{const sp=path.join(s,f),dp=path.join(d,f);fs.statSync(sp).isDirectory()?copyDir(sp,dp):fs.copyFileSync(sp,dp)})};copyDir('functions','dist/functions')\"",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler pages deploy dist",
    "deploy:static": "npm run build:static && wrangler pages deploy dist"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^6.4.2",
    "axios": "^1.5.0",
    "dayjs": "^1.11.9",
    "pinia": "^2.1.6",
    "vue": "^3.3.4",
    "vue-router": "^4.2.4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^4.3.4",
    "@vue/server-renderer": "^3.5.27",
    "autoprefixer": "^10.4.15",
    "jsdom": "^27.4.0",
    "postcss": "^8.4.29",
    "tailwindcss": "^3.3.3",
    "terser": "^5.46.0",
    "vite": "^4.4.9",
    "wrangler": "^4.72.0"
  }
}
